app/public/wp-config.php
app/public/.htaccess

# Configuration folders
conf/

# Composer
vendor/
app/public/vendor/
app/public/composer.lock

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.lock

# Logs
logs/
*.log

# Environment
.env
.env.*
!.env.example

# Cache
.cache/
*.cache
app/public/.phpunit.cache/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

