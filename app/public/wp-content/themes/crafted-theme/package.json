{
  "name": "crafted-theme",
  "version": "1.0.0",
  "description": "",
  "main": "gulpfile.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "start": "gulp",
    "build": "gulp build",
    "lint:php": "composer phpcs",
    "lint:php-fix": "composer phpcbf",
    "phpstan": "composer phpstan",
    "test:php": "composer test",
    "lint:js": "eslint assets/js/**/*.js",
    "lint:js-fix": "eslint assets/js/**/*.js --fix",
    "lint:css": "stylelint assets/scss/**/*.scss",
    "lint:css-fix": "stylelint assets/scss/**/*.scss --fix",
    "lint": "npm run lint:php && npm run lint:js && npm run lint:css",
    "lint-fix": "npm run lint:php-fix && npm run lint:js-fix && npm run lint:css-fix",
    "format": "prettier --write \"assets/js/**/*.js\" \"assets/scss/**/*.scss\"",
    "test": "npm run test:php",
    "quality": "npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gillmourtunhira/crafted-theme.git"
  },
  "keywords": [
    "wordpress",
    "theme",
    "gulp",
    "bootstrap",
    "sass"
  ],
  "author": "Gillmour Tunhira",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gillmourtunhira/crafted-theme/issues"
  },
  "homepage": "https://github.com/gillmourtunhira/crafted-theme#readme",
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.4.21",
    "browser-sync": "^3.0.4",
    "cssnano": "^7.1.0",
    "gulp": "^5.0.1",
    "gulp-concat": "^2.6.1",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-terser": "^2.1.0",
    "postcss": "^8.5.6",
    "sass": "^1.89.2",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-order": "^6.0.0",
    "gulp-eslint": "^6.0.0",
    "gulp-prettier": "^4.0.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "gulp-plumber": "^1.2.1",
    "gulp-uglify": "^3.0.2",
    "jquery": "^3.7.1"
  }
}
